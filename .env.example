# ── Target environment ────────────────────────────────────────────────────────
ENV=dev

# ── Application URLs ──────────────────────────────────────────────────────────
# Dev / staging / prod — switch ENV and update the URL accordingly
BASE_URL=https://practicetestautomation.com/practice-test-login/

# For staging, you might use:
# BASE_URL=https://staging.yourapp.com/login

# ── Test credentials ──────────────────────────────────────────────────────────
# These are the demo site's publicly documented credentials.
# In a real project, store actual secrets in your CI secrets manager.
VALID_USERNAME=student
VALID_PASSWORD=Password123

# ── Browser settings ──────────────────────────────────────────────────────────
# Set HEADLESS=false to watch tests run in a real browser window
HEADLESS=true

# Milliseconds delay between Playwright actions (0 = fastest, 500+ = demo mode)
SLOW_MO=0

# Global element timeout in milliseconds
BROWSER_TIMEOUT=30000

# ── Reporting ─────────────────────────────────────────────────────────────────
SCREENSHOT_DIR=screenshots
REPORT_DIR=reports

# Save a Playwright trace zip on test failure (open with: playwright show-trace)
TRACE_ON_FAILURE=true
